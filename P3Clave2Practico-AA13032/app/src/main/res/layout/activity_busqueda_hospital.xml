<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buscar hospital"
            android:textColor="@color/texto_principal"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:hint="Codigo o nombre del hospital">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtBuscarIdHospital"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBuscarHospital"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="14dp"
            android:text="Consultar hospital"
            app:cornerRadius="8dp" />

        <LinearLayout
            android:id="@+id/tarjetaResultadoHospital"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/fondo_tarjeta"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/lblNombreHospital"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/texto_principal"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lblCapacidadHospital"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/texto_secundario"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/lblEspecialidadesHospital"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/texto_secundario"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
