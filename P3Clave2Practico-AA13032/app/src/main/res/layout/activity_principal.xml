<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/fondo_resumen_azul"
                android:gravity="center"
                android:text="MC"
                android:textColor="@color/azul_secundario"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MedControl AA13032"
                    android:textColor="@color/texto_principal"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Red local de hospitales y doctores"
                    android:textColor="@color/texto_secundario"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/fondo_degradado"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_badge"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="Gestion medica local"
                android:textColor="@color/teal_salud"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Control de personal medico y hospitales"
                android:textColor="@color/blanco"
                android:textSize="23sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Administra registros medicos con busqueda rapida y datos organizados por hospital."
                android:textColor="@color/blanco"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Accesos rapidos"
            android:textColor="@color/texto_principal"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:columnCount="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegistrarHospital"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:gravity="center"
                android:text="Registrar\nhospital"
                android:textColor="@color/blanco"
                android:textSize="13sp"
                app:backgroundTint="@color/azul_secundario"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textStart"
                app:iconTint="@color/blanco" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuscarHospital"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:gravity="center"
                android:text="Buscar\nhospital"
                android:textColor="@color/azul_primario"
                android:textSize="13sp"
                app:backgroundTint="@color/azul_suave"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_menu_search"
                app:iconGravity="textStart"
                app:iconTint="@color/azul_secundario"
                app:strokeColor="@color/borde_suave"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegistrarDoctor"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:gravity="center"
                android:text="Registrar\ndoctor"
                android:textColor="@color/azul_primario"
                android:textSize="13sp"
                app:backgroundTint="@color/teal_suave"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textStart"
                app:iconTint="@color/teal_salud"
                app:strokeColor="@color/borde_suave"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnListarDoctores"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:gravity="center"
                android:text="Listar\ndoctores"
                android:textColor="@color/blanco"
                android:textSize="13sp"
                app:backgroundTint="@color/azul_primario"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_menu_sort_by_size"
                app:iconGravity="textStart"
                app:iconTint="@color/blanco" />
        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Resumen del modulo"
            android:textColor="@color/texto_principal"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="104dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/fondo_resumen_blanco"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/lblTotalHospitales"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/azul_secundario"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hospitales registrados"
                    android:textColor="@color/texto_secundario"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="104dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/fondo_resumen_blanco"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/lblTotalDoctores"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/teal_salud"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Medicos registrados"
                    android:textColor="@color/texto_secundario"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/fondo_tarjeta"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Flujo recomendado"
                android:textColor="@color/texto_principal"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="1. Registra un hospital nuevo.\n2. Busca el hospital por codigo o nombre.\n3. Registra un doctor y vinculalo al hospital.\n4. Revisa el listado actualizado."
                android:textColor="@color/texto_secundario"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
